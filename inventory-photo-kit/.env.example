# Copy this file to `.env` for local development.
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Alternative name supported by Google tooling:
# GOOGLE_API_KEY=

# Optional: plain-text file containing only the key.
# Keep `apikey_test` empty in git. Put real keys only in ignored local files.
# GEMINI_API_KEY_FILE=apikey_test.local
