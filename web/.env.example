# Copy this file to `.env.local` if you want persistent frontend settings.
# The default local run command already sets this value in the terminal.

# Backend API used by the local Vite app.
VITE_CLASSIFY_API_URL=http://127.0.0.1:8076

# Optional local shortcut: redirect "/" to "/sorter" and skip the login screen.
# Pair this with backend SKIP_AUTH=1.
# VITE_SKIP_AUTH=true

# Optional real auth testing. Leave empty for normal local team development.
# VITE_USE_IDP_IN_DEV=true
VITE_IDP_API_KEY=
VITE_IDP_TENANT_ID=
